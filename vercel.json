{
  "buildCommand": "npm run build",
  "functions": {
    "api/search.js": {
      "maxDuration": 60
    },
    "api/search-upload.js": {
      "maxDuration": 60
    },
    "api/search-health.js": {
      "maxDuration": 10
    },
    "api/search-history.js": {
      "maxDuration": 10
    },
    "api/search-sync-status.js": {
      "maxDuration": 10
    },
    "api/shared-context/snapshot.js": {
      "maxDuration": 10
    },
    "api/shared-context/publish.js": {
      "maxDuration": 10
    },
    "api/shared-context/delegate.js": {
      "maxDuration": 10
    },
    "api/sync-bridge/health.js": {
      "maxDuration": 10
    },
    "api/sync-bridge/accounts/[userId].js": {
      "maxDuration": 10
    },
    "api/og/[id].tsx": {
      "maxDuration": 10
    },
    "api/harness.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/og/:id", "destination": "/api/og/[id]" },
    { "source": "/api/harness/:path*", "destination": "/api/harness" },
    { "source": "/api/sweep/:path*", "destination": "/api/search" },
    { "source": "/api/search/insights", "destination": "/api/search" },
    { "source": "/install.sh", "destination": "https://raw.githubusercontent.com/HomenShum/nodebench-ai/main/packages/mcp-local/scripts/install.sh" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
