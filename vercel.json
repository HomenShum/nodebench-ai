{
  "buildCommand": "bash scripts/vercel-build.sh",
  "git": {
    "deploymentEnabled": {
      "dependabot/npm_and_yarn/*": false,
      "dependabot/pip/*": false,
      "dependabot/github_actions/*": false
    }
  },
  "ignoreCommand": "bash scripts/vercel-ignore-build.sh",
  "functions": {
    "api/search.js": {
      "maxDuration": 60
    },
    "api/search-upload.js": {
      "maxDuration": 60
    },
    "api/search-health.js": {
      "maxDuration": 10
    },
    "api/search-history.js": {
      "maxDuration": 10
    },
    "api/search-sync-status.js": {
      "maxDuration": 10
    },
    "api/shared-context/snapshot.js": {
      "maxDuration": 10
    },
    "api/shared-context/publish.js": {
      "maxDuration": 10
    },
    "api/shared-context/delegate.js": {
      "maxDuration": 10
    },
    "api/sync-bridge/health.js": {
      "maxDuration": 10
    },
    "api/sync-bridge/accounts/[userId].js": {
      "maxDuration": 10
    },
    "api/og/[id].tsx": {
      "maxDuration": 10
    },
    "api/harness.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/api/og/:id", "destination": "/api/og/[id]" },
    { "source": "/api/harness/:path*", "destination": "/api/harness" },
    { "source": "/api/shared-context/episodes", "destination": "/api/shared-context/snapshot?__nb_shared_context_path=episodes" },
    { "source": "/api/shared-context/episodes/start", "destination": "/api/shared-context/snapshot?__nb_shared_context_path=episodes/start" },
    { "source": "/api/shared-context/episodes/:episodeId", "destination": "/api/shared-context/snapshot?__nb_shared_context_path=episodes/:episodeId" },
    { "source": "/api/shared-context/episodes/:episodeId/span", "destination": "/api/shared-context/snapshot?__nb_shared_context_path=episodes/:episodeId/span" },
    { "source": "/api/shared-context/episodes/:episodeId/finalize", "destination": "/api/shared-context/snapshot?__nb_shared_context_path=episodes/:episodeId/finalize" },
    { "source": "/api/subconscious/:path*", "destination": "/api/shared-context/snapshot?__nb_passthrough_path=subconscious/:path*" },
    { "source": "/api/sweep/:path*", "destination": "/api/search" },
    { "source": "/api/search/stream", "destination": "/api/search" },
    { "source": "/api/search/insights", "destination": "/api/search" },
    { "source": "/install.sh", "destination": "https://raw.githubusercontent.com/HomenShum/nodebench-ai/main/packages/mcp-local/scripts/install.sh" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
