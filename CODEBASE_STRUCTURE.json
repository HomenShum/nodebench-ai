{
  "$schema": "NodeBench AI — Target Directory Structure",
  "$description": "Restructured codebase optimized for agentic development. 680 src files, 260 MCP tools, 52→18 convex domains.",
  "$principles": [
    "3-4 level max depth",
    "barrel exports (index.ts) at every directory",
    "co-located tests/hooks/types with features",
    "single source of truth (no duplicates)",
    "grep-friendly naming (useXxx, XxxView, XxxPanel)",
    "progressive disclosure (shared → features → widgets)"
  ],

  "root": {
    "_keep": ["README.md", "CLAUDE.md", "AGENTS.md", "package.json", "tsconfig.json", "vite.config.ts", "vitest.config.ts", "tailwind.config.js", "playwright.config.ts", ".gitignore", ".env.example"],

    "docs/": {
      "_purpose": "All documentation consolidated (127 root .md files → here)",
      "architecture/": ["AGENTS.md", "AI_FLYWHEEL.md", "ORACLE_VISION.md", "STATE_TRACKER.md"],
      "completions/": "All *COMPLETE*.md, *SUMMARY*.md (80+ files)",
      "plans/": "All *PLAN*.md, *ROADMAP*.md, *PRD*.md",
      "reports/": "All LIGHTHOUSE_*, TEST_REPORT*, ANALYSIS* docs",
      "changelog/": ["CHANGELOG.md", "FIXES.md"]
    },

    "src/": {
      "_purpose": "Frontend — React + Tailwind (680 files)",

      "app/": {
        "_purpose": "App shell — entry point, providers, global styles (FSD Layer 7)",
        "_files": ["App.tsx", "main.tsx", "index.css", "vite-env.d.ts"],
        "providers/": ["ThemeContext.tsx", "OracleSessionContext.tsx"]
      },

      "layouts/": {
        "_purpose": "Page-level layout shells (FSD Layer 6)",
        "_files": ["MainLayout.tsx", "CockpitLayout.tsx", "cockpitModes.ts"]
      },

      "pages/": {
        "_purpose": "Route-level entry points (FSD Layer 5)",
        "_files": ["EmailPage.tsx", "SignInForm.tsx", "SignOutButton.tsx"]
      },

      "features/": {
        "_purpose": "Domain features — each self-contained with components/hooks/views/types (FSD Layer 4)",
        "_count": "18 features (consolidated from 22)",

        "research/": {
          "_files": 131,
          "_purpose": "Research hub, signals, briefings, entity profiles, GitHub explorer",
          "components/": "90 research-specific components",
          "views/": "8 route-level views (ResearchHub, FundingBrief, etc.)",
          "hooks/": "9 research hooks (useBriefData, usePersonalBrief, etc.)",
          "sections/": "3 layout sections",
          "types/": "3 type definition files",
          "contexts/": "2 React contexts"
        },

        "agents/": {
          "_files": 125,
          "_purpose": "FastAgentPanel, marketplace, task manager, swarm orchestration",
          "components/": {
            "FastAgentPanel/": "87 files — primary agent interaction surface",
            "TaskManager/": "6 files — task session management",
            "_other": "18 standalone agent components"
          },
          "views/": "3 route-level views",
          "hooks/": "3 agent-specific hooks",
          "context/": "3 context providers",
          "types/": "1 type file"
        },

        "documents/": {
          "_files": "62 (absorbs spreadsheets/)",
          "_purpose": "Document grid, editors, hub, spreadsheets, file viewer",
          "components/": "49 doc components + documentsHub sub-structure",
          "editors/": "4 inline editors",
          "views/": "4 + SpreadsheetView (absorbed)"
        },

        "calendar/": { "_files": 16, "_purpose": "Calendar views, event/task editors, agenda" },
        "editor/": { "_files": 25, "_purpose": "Unified rich text editor with inspector panel" },
        "narrative/": { "_files": 25, "_purpose": "Narrative roadmap, correlation lines, thread lanes" },
        "analytics/": { "_files": 3, "_purpose": "Component metrics, HITL analytics, recommendation analytics" },
        "benchmarks/": { "_files": 4, "_purpose": "Model leaderboard, scenario catalog, workbench" },
        "social/": { "_files": 2, "_purpose": "LinkedIn post card, archive" },
        "email/": {
          "_files": "8 (absorbs emailIntelligence/)",
          "_purpose": "Email inbox, thread detail, scrollytelling, smart links"
        },
        "monitoring/": { "_files": 1, "_purpose": "PR suggestions" },
        "admin/": { "_files": 2, "_purpose": "Funding data review" },
        "onboarding/": {
          "_files": "11 (absorbs proactive/)",
          "_purpose": "Agent-guided onboarding, consent, preferences"
        },
        "oracle/": { "_files": 6, "_purpose": "Oracle career trajectory platform" },
        "dogfood/": { "_files": 1, "_purpose": "Dogfood review view" },
        "mcp/": { "_files": 1, "_purpose": "MCP tool ledger view" },
        "engine/": { "_files": 1, "_purpose": "Engine demo view" },
        "chat/": { "_files": 2, "_purpose": "Chat interface" }
      },

      "widgets/": {
        "_purpose": "Standalone composed UI blocks extracted from 44-file src/components/ (FSD Layer 3)",
        "_files": ["CommandPalette.tsx", "SettingsModal.tsx", "CostDashboard.tsx", "PersonalDashboard.tsx", "IndustryUpdatesPanel.tsx"],
        "sidebar/": ["CleanSidebar.tsx", "SidebarGlobalNav.tsx", "UserProfile.tsx", "navigation/"],
        "header/": ["CleanHeader.tsx"],
        "skeletons/": ["ViewSkeleton.tsx", "CostDashboardSkeleton.tsx", "IndustryUpdatesSkeleton.tsx"],
        "hud/": "11 HUD components (from src/components/hud/)"
      },

      "shared/": {
        "_purpose": "Shared primitives — ONE source of truth (FSD Layer 2-3)",

        "ui/": {
          "_purpose": "SINGLE UI library (merged from components/ui + shared/ui — no duplicates)",
          "_files": ["Button.tsx", "Card.tsx", "Badge.tsx", "EmptyState.tsx", "Toast.tsx", "Tooltip.tsx", "SidebarButton.tsx", "Sparkline.tsx", "SignatureOrb.tsx", "PresetChip.tsx", "UnifiedHubPills.tsx", "TopDividerBar.tsx", "PageHeroHeader.tsx", "index.ts"]
        },

        "components/": {
          "_purpose": "Shared composed components (ONE ErrorBoundary)",
          "_files": ["ErrorBoundary.tsx", "LazyView.tsx", "DialogOverlay.tsx", "FileDropOverlay.tsx", "MetaPills.tsx", "PresenceIndicator.tsx", "SkipLinks.tsx", "index.ts"]
        },

        "hooks/": {
          "_purpose": "ALL non-feature hooks consolidated (from 11 locations → 1)",
          "_files": ["useCommandPalette.ts", "useFocusTrap.ts", "useKeyboardNavigation.ts", "usePanelResize.ts", "useReducedMotion.ts", "useStableQuery.ts", "useWebMcpProvider.ts", "useEngagementTracking.ts", "useIntentTelemetry.ts", "useFeedback.ts", "index.ts"]
        },

        "editors/": ["PopoverMiniDocEditor.tsx", "MiniEditorPopover.tsx"],

        "lib/": {
          "_purpose": "Pure utilities — no React (merged from src/utils + src/lib)",
          "_files": ["briefDate.ts", "buttonClasses.ts", "calendarHelpers.ts", "displayText.ts", "fileTypes.ts", "formatNumber.ts", "ids.ts", "sources.ts", "tasks.ts", "timezones.ts", "utils.ts", "a11y.ts", "animations.ts", "viewRegistry.ts", "viewCapabilityRegistry.ts", "viewToolMap.ts"]
        }
      },

      "types/": { "_purpose": "Global TypeScript types", "_files": ["theme.ts"] },
      "test/": { "_purpose": "Frontend test utilities", "_files": "15 test files" }
    },

    "convex/": {
      "_purpose": "Backend — Convex functions (consolidated from 52 → 18 domains)",

      "domains/": {
        "agents/": { "_files": 50, "_purpose": "Agent OS, navigation, traversal, feed, view manifest" },
        "research/": { "_files": "38 + absorbed enrichment + signals + forecasting", "_purpose": "Research pipeline, entity enrichment, signal detection" },
        "social/": { "_files": "24 + absorbed channels + messaging + publishing", "_purpose": "LinkedIn, channels, messaging" },
        "documents/": { "_files": "29 + absorbed artifacts + knowledge + search", "_purpose": "Document storage, artifacts, knowledge base" },
        "evaluation/": { "_files": "35 + absorbed eval + groundTruth + testing + validation", "_purpose": "All evaluation and testing infrastructure" },
        "financial/": { "_files": "25 + absorbed billing", "_purpose": "Financial data, funding, billing" },
        "operations/": { "_files": "15 + absorbed monitoring + observability + telemetry", "_purpose": "Ops, self-healing, health monitoring" },
        "ai/": { "_files": 8, "_purpose": "AI models, LLM routing, transcription" },
        "integrations/": { "_files": 14, "_purpose": "External service bridges" },
        "calendar/": { "_files": "absorbed tasks + taskManager", "_purpose": "Calendar, tasks, task management" },
        "narrative/": { "_files": "absorbed dossier + personas", "_purpose": "Narrative generation, dossiers" },
        "proactive/": { "_files": "absorbed recommendations", "_purpose": "Proactive suggestions, recommendations" },
        "governance/": { "_files": "absorbed verification", "_purpose": "Design governance, verification, compliance" },
        "analytics/": { "_files": "absorbed blips + hitl", "_purpose": "Analytics, engagement blips, HITL metrics" },
        "users/": { "_purpose": "Operator profiles, encounters, landing" },
        "dogfood/": { "_purpose": "Dogfood review data" },
        "openclaw/": { "_purpose": "OpenClaw sandbox" },
        "batch/": { "_purpose": "Batch autopilot, quick capture" }
      },

      "workflows/": { "_files": 17, "_purpose": "Workflow orchestration" },
      "crons/": { "_files": 7, "_purpose": "Scheduled jobs" },
      "lib/": { "_files": 25, "_purpose": "Shared utilities" },
      "http/": { "_files": 2, "_purpose": "HTTP endpoints" }
    },

    "packages/": {
      "mcp-local/": {
        "_purpose": "MCP Server — 260 tools",
        "src/": {
          "_root_files": ["index.ts", "toolsetRegistry.ts", "db.ts", "types.ts", "sandboxApi.ts"],

          "tools/": {
            "_purpose": "Tool implementations grouped by domain (from 55 flat files → 11 subdirs)",
            "discovery/": ["progressiveDiscoveryTools.ts", "toolRegistry.ts", "metaTools.ts"],
            "agent/": ["agentBootstrapTools.ts", "parallelAgentTools.ts", "sessionMemoryTools.ts"],
            "code/": ["architectTools.ts", "boilerplateTools.ts", "gitWorkflowTools.ts", "prReportTools.ts"],
            "research/": ["researchOptimizerTools.ts", "researchWritingTools.ts", "rssTools.ts", "webTools.ts"],
            "eval/": ["evalTools.ts", "selfEvalTools.ts", "critterTools.ts", "cCompilerBenchmarkTools.ts"],
            "content/": ["toonTools.ts", "patternTools.ts", "seoTools.ts", "skillUpdateTools.ts", "thompsonProtocolTools.ts"],
            "media/": ["visionTools.ts", "visualQaTools.ts", "uiCaptureTools.ts", "flickerDetectionTools.ts", "figmaFlowTools.ts"],
            "data/": ["localFileTools.ts", "emailTools.ts", "scraplingTools.ts", "forecastingTools.ts"],
            "ops/": ["qualityGateTools.ts", "verificationTools.ts", "localDashboardTools.ts", "observatoryTools.ts"],
            "bridge/": ["mcpBridgeTools.ts", "voiceBridgeTools.ts", "webmcpTools.ts", "llmTools.ts", "openclawTools.ts"],
            "platform/": ["uiUxDiveTools.ts", "uiUxDiveV2Tools.ts", "githubTools.ts", "designGovernanceTools.ts"]
          },

          "security/": { "_files": 8, "_purpose": "4-layer defense (keep as-is)" },
          "engine/": { "_files": 4, "_purpose": "Workflow engine (keep)" },
          "analytics/": { "_files": 6, "_purpose": "Metrics/telemetry (keep)" },
          "dashboard/": { "_files": 4, "_purpose": "Local dashboard backend (keep)" },

          "__tests__/": {
            "_purpose": "Test suite grouped by concern (from 33 flat → 6 subdirs)",
            "unit/": ["tools.test.ts", "embeddingProvider.test.ts", "analytics.test.ts"],
            "eval/": ["evalHarness.test.ts", "evalDatasetBench.test.ts", "comparativeBench.test.ts", "critterCalibrationEval.ts"],
            "integration/": ["cliSubcommands.test.ts", "localDashboard.test.ts", "webmcpTools.test.ts", "batchAutopilot.test.ts"],
            "dogfood/": ["multiHopDogfood.test.ts", "openclawDogfood.test.ts", "traceabilityDogfood.test.ts", "forecastingDogfood.test.ts"],
            "bench/": ["presetRealWorldBench.test.ts", "toolsetGatingEval.test.ts", "openDatasetParallelEval.test.ts"],
            "fixtures/": "11 test data files",
            "helpers/": "2 test utility files"
          }
        }
      },

      "convex-mcp-nodebench/": { "_purpose": "Convex MCP Server — 36 tools (keep structure)" }
    },

    "tests/": { "_purpose": "E2E Playwright tests (keep)" },
    "public/": { "_purpose": "Static assets, dogfood screenshots (keep)" },
    "python-mcp-servers/": { "_purpose": "Python FastAPI services (keep)" },
    "scripts/": {
      "ui/": "UI capture, dogfood, design linting",
      "sentinel/": "Self-testing system",
      "design/": "Figma, onboarding capture",
      "ops/": "Orphan scripts moved from root (fix-accent.cjs, post-linkedin.mjs, etc.)"
    }
  }
}
